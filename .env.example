# This is an example environment file template for Next.js.
# Copy this file to .env or .env.local and update the values for your local development environment.
# Do not commit your actual .env files to version control!

# --- System ---
NODE_ENV=development
PORT=3000

# --- Database (Example) ---
# DATABASE_URL="postgresql://user:password@localhost:5432/mydb?schema=public"

# --- API Keys (Examples based on Next.js/AI typical usage) ---
# OPENAI_API_KEY="sk-..."
# NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="ey..."

# --- Authentication ---
# NEXTAUTH_URL="http://localhost:3000"
# NEXTAUTH_SECRET="generate-a-random-secret-here"
